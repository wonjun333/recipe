# Development defaults
# In the current external environment, use mock data unless you are on the
# internal network with access to the real infrastructure.
RECIPE_USE_MOCK=true

# Shared/Postgres settings for backend/db.py
DB_HOST=127.0.0.1
DB_PORT=5432
DB_NAME=postgres
DB_USER=postgres
DB_PASSWORD=

# App service connection settings
POSTGRES_URL=
MONGO_URL=mongodb://127.0.0.1:27017/
