# --- Corporate runtime environment ---
POSTGRES_URL=postgresql+psycopg://<user>:<password>@<host>:<port>/<dbname>
MONGO_URL=mongodb://<host>:<port>/
CORS_ORIGINS=http://localhost:5173,http://localhost:5174,http://<server-host>:8282

# --- SAML auth ---
AUTH_COOKIE_NAME=auth_token
JWT_CERT_PATH=../Nodejs_SAML/cert/cert.pem

# --- Runtime data paths ---
# Windows development example:
# RECIPE_DATA_DIR=C:\ProgramData\RecipeRMS
# Ubuntu build/deploy example:
# RECIPE_DATA_DIR=/opt/recipe-rms/data

# --- Recipe Cache DB (optional PostgreSQL instead of local SQLite) ---
# RECIPE_CACHE_DB_URL=postgresql://<user>:<password>@<host>:<port>/recipe_db
