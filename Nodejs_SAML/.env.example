PORT=44364
MOCK_MODE=true

# --- JWT (FastAPI backend의 AUTH_JWT_SECRET 과 반드시 동일하게 설정) ---
AUTH_JWT_SECRET=change-me-in-production
AUTH_JWT_EXPIRE_HOURS=8

# --- 로그인 성공 후 이동할 Vue 프론트엔드 주소 ---
SAML_REDIRECT_AFTER_LOGIN=http://localhost:5174/

# --- SAML 설정 (MOCK_MODE=false 시 필수) ---
SAML_IDP_URL=
SAML_ENTITY_ID=https://localhost:44364
SAML_ACS_URL=https://localhost:44364/samlconsume
SAML_IDP_CERT=
SAML_SIGNOUT_URL=
